@implements IDisposable

@using ORBE_WMS.WebApp.Services
@inject NavigationManager NavigationManager
@inject TabService TabService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">ORBE WMS</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-section-label">Operações</div>

        <div class="nav-item px-3">
            <a class="nav-link @ActiveClass(typeof(Pages.Home))" href="/?tab=dashboard" @onclick="OpenDashboard" @onclick:preventDefault>
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </a>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link @ActiveClass(typeof(Pages.Recebimento))" href="/?tab=recebimento" @onclick="OpenRecebimento" @onclick:preventDefault>
                <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> Recebimento
            </a>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link @ActiveClass(typeof(Pages.Estoque))" href="/?tab=estoque" @onclick="OpenEstoque" @onclick:preventDefault>
                <span class="bi bi-box-nav-menu" aria-hidden="true"></span> Estoque
            </a>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link @ActiveClass(typeof(Pages.Separacao))" href="/?tab=separacao" @onclick="OpenSeparacao" @onclick:preventDefault>
                <span class="bi bi-scissors-nav-menu" aria-hidden="true"></span> Separação
            </a>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link @ActiveClass(typeof(Pages.Expedicao))" href="/?tab=expedicao" @onclick="OpenExpedicao" @onclick:preventDefault>
                <span class="bi bi-truck-nav-menu" aria-hidden="true"></span> Expedição
            </a>
        </div>

        <hr class="nav-section-divider" />
        <div class="nav-section-label">Cadastros</div>

        <div class="nav-item px-3">
            <a class="nav-link @ActiveClass(typeof(Pages.Depositantes))" href="/?tab=depositantes" @onclick="OpenDepositantes" @onclick:preventDefault>
                <span class="bi bi-building-nav-menu" aria-hidden="true"></span> Depositantes
            </a>
        </div>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-item px-3">
                    <a class="nav-link @ActiveClass(typeof(Pages.Armazens))" href="/?tab=armazens" @onclick="OpenArmazens" @onclick:preventDefault>
                        <span class="bi bi-building-add-nav-menu" aria-hidden="true"></span> Armazéns
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link @ActiveClass(typeof(Pages.Usuarios))" href="/?tab=usuarios" @onclick="OpenUsuarios" @onclick:preventDefault>
                        <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Usuários
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>

        <hr class="nav-section-divider" />
        <div class="nav-section-label">Conta</div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        TabService.OnTabsChanged += HandleTabsChanged;
    }

    private void OpenDashboard() => TabService.OpenTab("Dashboard", "bi-house-door-fill", typeof(Pages.Home));
    private void OpenRecebimento() => TabService.OpenTab("Recebimento", "bi-box-arrow-in-right", typeof(Pages.Recebimento));
    private void OpenEstoque() => TabService.OpenTab("Estoque", "bi-box", typeof(Pages.Estoque));
    private void OpenSeparacao() => TabService.OpenTab("Separação", "bi-scissors", typeof(Pages.Separacao));
    private void OpenExpedicao() => TabService.OpenTab("Expedição", "bi-truck", typeof(Pages.Expedicao));
    private void OpenArmazens() => TabService.OpenTab("Armazéns", "bi-building-add", typeof(Pages.Armazens));
    private void OpenDepositantes() => TabService.OpenTab("Depositantes", "bi-building", typeof(Pages.Depositantes));
    private void OpenUsuarios() => TabService.OpenTab("Usuários", "bi-people-fill", typeof(Pages.Usuarios));

    private string ActiveClass(Type componentType)
    {
        var active = TabService.ActiveTab;
        return active is not null && active.ComponentType == componentType ? "active" : "";
    }

    private void HandleTabsChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        TabService.OnTabsChanged -= HandleTabsChanged;
    }
}
