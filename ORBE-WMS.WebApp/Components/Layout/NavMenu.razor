@implements IDisposable

@inject NavigationManager NavigationManager

<MudNavMenu Dense="true">

    @* === PRINCIPAL === *@
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>

    @* === OPERAÇÕES === *@
    <MudNavGroup Title="Operações" Icon="@Icons.Material.Filled.PlayCircle" Expanded="true">
        <MudNavLink Href="recebimento" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MoveToInbox">
            Recebimento
        </MudNavLink>
        <MudNavLink Href="estoque" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Inventory2">
            Estoque
        </MudNavLink>
        <MudNavLink Href="separacao" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ContentCut">
            Separação
        </MudNavLink>
        <MudNavLink Href="expedicao" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocalShipping">
            Expedição
        </MudNavLink>
    </MudNavGroup>

    @* === CADASTROS === *@
    <MudNavGroup Title="Cadastros" Icon="@Icons.Material.Filled.FolderOpen" Expanded="false">
        <MudNavLink Href="depositantes" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Business">
            Depositantes
        </MudNavLink>
    </MudNavGroup>

    @* === ADMINISTRAÇÃO (Admin only) === *@
    <AuthorizeView Roles="Admin">
        <Authorized>
            <MudNavGroup Title="Administração" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="false">
                <MudNavLink Href="armazens" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Warehouse">
                    Armazéns
                </MudNavLink>
                <MudNavLink Href="admin/usuarios" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">
                    Usuários
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

    <MudDivider Class="my-2" />

    @* === CONTA === *@
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="Account/Manage" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountCircle">
                @context.User.Identity?.Name
            </MudNavLink>
            <MudNavLink Icon="@Icons.Material.Filled.Logout" OnClick="Logout">
                Sair
            </MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="Account/Login" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Login">
                Login
            </MudNavLink>
        </NotAuthorized>
    </AuthorizeView>

</MudNavMenu>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private void Logout()
    {
        NavigationManager.NavigateTo("Account/Logout", forceLoad: true);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
