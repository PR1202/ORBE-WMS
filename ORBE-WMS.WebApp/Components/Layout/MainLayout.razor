@inherits LayoutComponentBase
@implements IDisposable

@using System.Text.Json
@using ORBE_WMS.WebApp.Services
@using Microsoft.AspNetCore.WebUtilities
@inject TabService TabService
@inject TenantService TenantService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="top-row-brand">
                <i class="bi bi-box-seam-fill me-2"></i>ORBE WMS
            </span>
            <TenantSelector />
        </div>

        @if (_isAccountPage)
        {
            <article class="content px-4">
                @Body
            </article>
        }
        else if (TabService.Tabs.Any())
        {
            <div class="tab-bar">
                <div class="tab-bar-inner">
                    @foreach (var tab in TabService.Tabs)
                    {
                        <div class="tab-item @(tab.IsActive ? "active" : "")"
                             @onclick="() => TabService.ActivateTab(tab.Id)">
                            <i class="bi @tab.Icon tab-icon"></i>
                            <span class="tab-title">@tab.Title</span>
                            @if (!tab.IsPinned)
                            {
                                <button class="tab-close" title="Fechar aba"
                                        @onclick="() => CloseTab(tab.Id)"
                                        @onclick:stopPropagation="true">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="tab-content-area px-4">
                @foreach (var tab in TabService.Tabs)
                {
                    <div style="display: @(tab.IsActive ? "block" : "none")">
                        <DynamicComponent Type="tab.ComponentType" />
                    </div>
                }
            </div>
        }
        else
        {
            <article class="content px-4">
                @Body
            </article>
        }
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isAccountPage;
    private bool _initialized;

    // Mapeamento componentKey <-> (título, ícone, tipo)
    private static readonly Dictionary<string, (string Title, string Icon, Type Component)> TabMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["dashboard"]    = ("Dashboard",    "bi-house-door-fill",    typeof(Pages.Home)),
        ["recebimento"]  = ("Recebimento",  "bi-box-arrow-in-right", typeof(Pages.Recebimento)),
        ["estoque"]      = ("Estoque",      "bi-box",                typeof(Pages.Estoque)),
        ["separacao"]    = ("Separação",    "bi-scissors",           typeof(Pages.Separacao)),
        ["expedicao"]    = ("Expedição",    "bi-truck",              typeof(Pages.Expedicao)),
        ["depositantes"] = ("Depositantes", "bi-building",           typeof(Pages.Depositantes)),
        ["armazens"]     = ("Armazéns",     "bi-building-add",       typeof(Pages.Armazens)),
        ["usuarios"]     = ("Usuários",     "bi-people-fill",        typeof(Pages.Usuarios)),
    };

    // Mapeamento reverso: Type -> key
    private static readonly Dictionary<Type, string> TypeToKey = TabMap.ToDictionary(kv => kv.Value.Component, kv => kv.Key);

    protected override void OnInitialized()
    {
        TabService.OnTabsChanged += HandleTabsChanged;
        TenantService.OnContextChanged += HandleContextChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
        UpdateAccountPageFlag();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isAccountPage)
        {
            _initialized = true;
            await RestoreTabsAsync();
        }
    }

    /// <summary>
    /// Chamado quando o TenantSelector troca de contexto (armazém/depositante).
    /// Restaura as abas do novo contexto ou abre Dashboard padrão.
    /// </summary>
    private async void HandleContextChanged()
    {
        var contextoKey = TenantService.ContextoKey;

        if (contextoKey is not null)
        {
            var savedTabs = TenantService.RestaurarAbasDoContexto(contextoKey);

            TabService.ClearAll();

            if (savedTabs is { Count: > 0 })
            {
                // Restaurar abas do contexto
                foreach (var st in savedTabs)
                {
                    if (TabMap.TryGetValue(st.Key, out var info))
                    {
                        if (st.Pinned)
                            TabService.OpenPinnedTab(info.Title, info.Icon, info.Component);
                        else
                            TabService.OpenTab(info.Title, info.Icon, info.Component);
                    }
                }

                // Ativar a aba que estava ativa
                var activeKey = savedTabs.FirstOrDefault(s => s.Active)?.Key;
                if (activeKey != null && TabMap.TryGetValue(activeKey, out var activeInfo))
                {
                    var activeTab = TabService.Tabs.FirstOrDefault(t => t.ComponentType == activeInfo.Component);
                    if (activeTab != null)
                        TabService.ActivateTab(activeTab.Id);
                }
            }
            else
            {
                // Sem histórico: abrir Dashboard padrão
                TabService.OpenPinnedTab("Dashboard", "bi-house-door-fill", typeof(Pages.Home));
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RestoreTabsAsync()
    {
        // 1. Tentar restaurar abas do sessionStorage (para refresh de página)
        var json = await JS.InvokeAsync<string>("tabStorage.load");
        var restored = false;

        if (!string.IsNullOrEmpty(json) && json != "[]")
        {
            try
            {
                var savedTabs = JsonSerializer.Deserialize<List<SavedTab>>(json);
                if (savedTabs is { Count: > 0 })
                {
                    TabService.ClearAll();

                    foreach (var st in savedTabs)
                    {
                        if (TabMap.TryGetValue(st.Key, out var info))
                        {
                            if (st.Pinned)
                                TabService.OpenPinnedTab(info.Title, info.Icon, info.Component);
                            else
                                TabService.OpenTab(info.Title, info.Icon, info.Component);
                        }
                    }

                    var activeKey = savedTabs.FirstOrDefault(s => s.Active)?.Key;
                    if (activeKey != null && TabMap.TryGetValue(activeKey, out var activeInfo))
                    {
                        var activeTab = TabService.Tabs.FirstOrDefault(t => t.ComponentType == activeInfo.Component);
                        if (activeTab != null)
                            TabService.ActivateTab(activeTab.Id);
                    }

                    restored = true;
                }
            }
            catch { /* JSON inválido, ignorar */ }
        }

        // 2. Se não restaurou do sessionStorage, criar Dashboard padrão
        if (!restored && !TabService.Tabs.Any())
        {
            TabService.OpenPinnedTab("Dashboard", "bi-house-door-fill", typeof(Pages.Home));
        }

        // 3. Verificar query parameter ?tab=xxx e abrir/ativar a aba correspondente
        OpenTabFromQuery();

        // 4. Salvar estado atual
        await SaveTabsAsync();

        StateHasChanged();
    }

    private void OpenTabFromQuery()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("tab", out var tabValue))
        {
            var tabKey = tabValue.ToString();
            if (TabMap.TryGetValue(tabKey, out var info))
            {
                TabService.OpenTab(info.Title, info.Icon, info.Component);
            }
        }
    }

    private async Task SaveTabsAsync()
    {
        if (!_initialized) return;

        try
        {
            var savedTabs = TabService.Tabs.Select(t => new SavedTab
            {
                Key = TypeToKey.GetValueOrDefault(t.ComponentType, ""),
                Pinned = t.IsPinned,
                Active = t.IsActive
            }).Where(s => !string.IsNullOrEmpty(s.Key)).ToList();

            var json = JsonSerializer.Serialize(savedTabs);
            await JS.InvokeVoidAsync("tabStorage.save", json);
        }
        catch { /* Ignorar erros de JS durante SSR */ }
    }

    private void UpdateAccountPageFlag()
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        _isAccountPage = uri.StartsWith("Account/", StringComparison.OrdinalIgnoreCase);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateAccountPageFlag();
        InvokeAsync(StateHasChanged);
    }

    private void CloseTab(Guid tabId)
    {
        TabService.CloseTab(tabId);
    }

    private async void HandleTabsChanged()
    {
        await SaveTabsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TabService.OnTabsChanged -= HandleTabsChanged;
        TenantService.OnContextChanged -= HandleContextChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private class SavedTab
    {
        public string Key { get; set; } = "";
        public bool Pinned { get; set; }
        public bool Active { get; set; }
    }
}
