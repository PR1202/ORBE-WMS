@inherits LayoutComponentBase

<div class="account-layout">
    <div class="account-card card shadow-lg bg-white">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="account-logo mb-2">
                    <i class="bi bi-box-seam-fill"></i>
                </div>
                <h2 class="mb-1">
                    <span class="fw-bold" style="color: var(--orbe-primary, #0F4C81);">ORBE</span>
                    <span class="fw-light" style="color: var(--orbe-text-secondary, #475569);">WMS</span>
                </h2>
                <span style="color: var(--orbe-text-muted, #94A3B8); font-size: 0.8rem;">
                    Sistema de Gerenciamento de Armazém
                </span>
            </div>
            <hr class="mb-4" />
            @Body
        </div>
    </div>
</div>
