@page "/admin/usuarios"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ORBE_WMS.WebApp.Data
@using ORBE_WMS.WebApp.Components.Dialogs

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Usuários - ORBE WMS</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Usuários</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="CriarUsuario">
        Novo Usuário
    </MudButton>
</MudStack>

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid Items="@_usuarios" Dense="true" Hover="true" Striped="true" Bordered="true"
                 FixedHeader="true" Height="calc(100vh - 230px)"
                 Filterable="true" FilterMode="DataGridFilterMode.Simple"
                 QuickFilter="@_quickFilter">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" Placeholder="Buscar usuário..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" Immediate="true" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Nome" Title="Nome" />
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <TemplateColumn Title="Status" Sortable="false" Filterable="false">
                <CellTemplate>
                    @if (context.Item.Ativo)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Ativo</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">Inativo</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Armazéns" Sortable="false" Filterable="false">
                <CellTemplate>
                    @if (context.Item.Armazens.Any())
                    {
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            @foreach (var ua in context.Item.Armazens)
                            {
                                <MudChip T="string" Color="Color.Info" Size="Size.Small">
                                    @ua.Armazem.Nome (@ua.Role)
                                </MudChip>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Nenhum</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Ações" Sortable="false" Filterable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="Editar">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => EditarUsuario(context.Item)" />
                        </MudTooltip>
                        <MudTooltip Text="Gerenciar Armazéns">
                            <MudIconButton Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small"
                                           Color="Color.Secondary"
                                           OnClick="() => GerenciarArmazens(context.Item)" />
                        </MudTooltip>
                        <MudTooltip Text="@(context.Item.Ativo ? "Desativar" : "Ativar")">
                            <MudIconButton Icon="@(context.Item.Ativo ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                           Size="Size.Small"
                                           Color="@(context.Item.Ativo ? Color.Success : Color.Default)"
                                           OnClick="() => ToggleAtivo(context.Item)" />
                        </MudTooltip>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText>Nenhum usuário encontrado.</MudText>
        </NoRecordsContent>
    </MudDataGrid>
}

@code {
    private List<ApplicationUser> _usuarios = [];
    private bool _carregando = true;
    private string? _searchString;

    private Func<ApplicationUser, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if (x.Nome.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.Email is not null && x.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    };

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        _carregando = true;
        Db.ChangeTracker.Clear();
        _usuarios = await Db.Users
            .AsNoTracking()
            .Include(u => u.Armazens)
                .ThenInclude(ua => ua.Armazem)
            .OrderBy(u => u.Nome)
            .ToListAsync();
        _carregando = false;
    }

    private async Task CriarUsuario()
    {
        var dialog = await DialogService.ShowAsync<UsuarioDialog>("Novo Usuário",
            new DialogParameters(),
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await CarregarDados();
            Snackbar.Add("Usuário criado com sucesso!", Severity.Success);
        }
    }

    private async Task EditarUsuario(ApplicationUser usuario)
    {
        var parameters = new DialogParameters
        {
            { nameof(UsuarioDialog.UsuarioId), usuario.Id }
        };

        var dialog = await DialogService.ShowAsync<UsuarioDialog>("Editar Usuário", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await CarregarDados();
            Snackbar.Add("Usuário atualizado com sucesso!", Severity.Success);
        }
    }

    private async Task GerenciarArmazens(ApplicationUser usuario)
    {
        var parameters = new DialogParameters
        {
            { nameof(UsuarioArmazensDialog.UsuarioId), usuario.Id },
            { nameof(UsuarioArmazensDialog.UsuarioNome), usuario.Nome }
        };

        var dialog = await DialogService.ShowAsync<UsuarioArmazensDialog>(
            $"Armazéns - {usuario.Nome}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await CarregarDados();
            Snackbar.Add("Vínculos de armazéns atualizados!", Severity.Success);
        }
    }

    private async Task ToggleAtivo(ApplicationUser usuario)
    {
        var acao = usuario.Ativo ? "desativar" : "ativar";
        var confirmed = await DialogService.ShowMessageBox(
            "Confirmar",
            $"Deseja {acao} o usuário \"{usuario.Nome}\"?",
            yesText: "Sim", cancelText: "Cancelar");

        if (confirmed == true)
        {
            var user = await UserManager.FindByIdAsync(usuario.Id);
            if (user is not null)
            {
                user.Ativo = !user.Ativo;
                await UserManager.UpdateAsync(user);
                await CarregarDados();
                Snackbar.Add($"Usuário {(user.Ativo ? "ativado" : "desativado")} com sucesso!", Severity.Success);
            }
        }
    }
}
