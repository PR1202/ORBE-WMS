@* Componente renderizado dentro do sistema de abas *@
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ORBE_WMS.Domain.Entities
@using ORBE_WMS.Infrastructure.Persistence
@using ORBE_WMS.WebApp.Services

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager
@inject TabService TabService
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Usuários - ORBE WMS</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Usuários</h4>
    <button class="btn btn-primary" @onclick="CriarUsuario">
        <i class="bi bi-person-plus-fill me-1"></i> Novo Usuário
    </button>
</div>

@if (_carregandoPrincipal)
{
    <div class="progress" style="height: 3px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex align-items-center">
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar usuário..." @bind="_searchString" @bind:event="oninput" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Armazéns</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (UsuariosFiltrados.Any())
                    {
                        @foreach (var context in UsuariosFiltrados)
                        {
                            <tr>
                                <td>@context.Nome</td>
                                <td>@context.Email</td>
                                <td>
                                    @if (context.Ativo)
                                    {
                                        <span class="badge bg-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inativo</span>
                                    }
                                </td>
                                <td>
                                    @if (context.Armazens.Any())
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var ua in context.Armazens)
                                            {
                                                <span class="badge bg-info text-dark">@ua.Armazem.Nome (@ua.Role)</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Nenhum</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" title="Editar" @onclick="() => EditarUsuario(context)">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary me-1" title="Gerenciar Armazéns" @onclick="() => GerenciarArmazens(context)">
                                        <i class="bi bi-building"></i>
                                    </button>
                                    <button class="btn btn-sm @(context.Ativo ? "btn-outline-danger" : "btn-outline-success") me-1" 
                                            title="@(context.Ativo ? "Desativar" : "Ativar")"
                                            @onclick="() => ToggleAtivo(context)">
                                        <i class="bi @(context.Ativo ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" title="Excluir" @onclick="() => Excluir(context)">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Nenhum usuário encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- WAREHOUSES MANAGEMENT MODAL (mantido conforme solicitado) -->
@if (_showArmazensModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-building me-2"></i>
                        Armazéns de @_usuarioArmazensNome
                    </h5>
                    <button type="button" class="btn-close" @onclick="FecharArmazensModal"></button>
                </div>
                <div class="modal-body">
                    @if (_carregandoArmazens)
                    {
                        <div class="progress" style="height: 3px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
                        </div>
                    }
                    else if (!_vinculos.Any())
                    {
                        <div class="alert alert-info py-2" role="alert">
                            Nenhum armazém cadastrado no sistema. Crie um armazém antes de vincular usuários.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-3">Selecione os armazéns e defina o papel do usuário em cada um.</p>

                        <div class="list-group">
                            @foreach (var item in _vinculos)
                            {
                                <div class="list-group-item d-flex align-items-center justify-content-between p-3">
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox" @bind="item.Vinculado" id="chk_@item.ArmazemId">
                                        <label class="form-check-label fw-bold" for="chk_@item.ArmazemId">
                                            @item.ArmazemNome
                                        </label>
                                    </div>
                                    <div style="width: 200px;">
                                        <select class="form-select form-select-sm" @bind="item.Role" disabled="@(!item.Vinculado)">
                                            <option value="Gerente">Gerente</option>
                                            <option value="Operador">Operador</option>
                                        </select>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="FecharArmazensModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="SalvarArmazens" disabled="@(_salvandoArmazens || _carregandoArmazens)">
                        @if (_salvandoArmazens)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ApplicationUser> _usuarios = [];
    private bool _carregandoPrincipal = true;
    private string _searchString = "";

    // MODAL STATE - WAREHOUSE MANAGEMENT (mantido)
    private bool _showArmazensModal = false;
    private string _usuarioArmazensId = "";
    private string _usuarioArmazensNome = "";
    private bool _carregandoArmazens = false;
    private bool _salvandoArmazens = false;
    private List<VinculoItem> _vinculos = [];

    private IEnumerable<ApplicationUser> UsuariosFiltrados => _usuarios.Where(x =>
        string.IsNullOrWhiteSpace(_searchString) ||
        x.Nome.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        (x.Email != null && x.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
    );

    private bool _wasActive = true;

    protected override async Task OnInitializedAsync()
    {
        TabService.OnTabsChanged += HandleTabFocus;
        await CarregarDados();
    }

    private async void HandleTabFocus()
    {
        var isActive = TabService.ActiveTab?.ComponentType == typeof(Usuarios);
        if (isActive && !_wasActive)
        {
            await InvokeAsync(async () =>
            {
                await CarregarDados();
                StateHasChanged();
            });
        }
        _wasActive = isActive;
    }

    private async Task CarregarDados()
    {
        _carregandoPrincipal = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _usuarios = await db.Users
            .AsNoTracking()
            .Include(u => u.Armazens)
                .ThenInclude(ua => ua.Armazem)
            .OrderBy(u => u.Nome)
            .ToListAsync();
        _carregandoPrincipal = false;
    }

    // === MÉTODOS DE USUÁRIO (agora via abas de formulário) ===
    private void CriarUsuario()
    {
        TabService.OpenFormTab("✚ Novo Usuário", "bi-person-plus-fill", typeof(FormUsuario), new Dictionary<string, object>
        {
            ["UsuarioId"] = ""
        });
    }

    private void EditarUsuario(ApplicationUser usuario)
    {
        TabService.OpenFormTab($"✏ Editar: {usuario.Nome}", "bi-pencil-square", typeof(FormUsuario), new Dictionary<string, object>
        {
            ["UsuarioId"] = usuario.Id
        });
    }

    private async Task ToggleAtivo(ApplicationUser usuario)
    {
        var user = await UserManager.FindByIdAsync(usuario.Id);
        if (user is not null)
        {
            user.Ativo = !user.Ativo;
            await UserManager.UpdateAsync(user);
            var status = user.Ativo ? "ativado" : "desativado";
            ToastService.Success($"Usuário \"{user.Nome}\" {status} com sucesso!");
            await CarregarDados();
        }
    }

    // === MÉTODOS DE ARMAZÉNS DO USUÁRIO (modal mantido) ===
    private async Task GerenciarArmazens(ApplicationUser usuario)
    {
        _usuarioArmazensId = usuario.Id;
        _usuarioArmazensNome = usuario.Nome;
        _showArmazensModal = true;
        _carregandoArmazens = true;

        await using var db = await DbFactory.CreateDbContextAsync();
        var armazensAll = await db.Armazens.AsNoTracking().Where(a => a.Ativo).OrderBy(a => a.Nome).ToListAsync();
        var vinculosExistentes = await db.UsuarioArmazens.AsNoTracking()
            .Where(ua => ua.UsuarioId == usuario.Id)
            .ToListAsync();

        _vinculos = armazensAll.Select(a =>
        {
            var existente = vinculosExistentes.FirstOrDefault(v => v.ArmazemId == a.Id);
            return new VinculoItem
            {
                ArmazemId = a.Id,
                ArmazemNome = a.Nome,
                Vinculado = existente is not null,
                Role = existente?.Role ?? "Operador"
            };
        }).ToList();

        _carregandoArmazens = false;
    }

    private void FecharArmazensModal()
    {
        _showArmazensModal = false;
    }

    private async Task SalvarArmazens()
    {
        _salvandoArmazens = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existentes = await db.UsuarioArmazens
                .Where(ua => ua.UsuarioId == _usuarioArmazensId)
                .ToListAsync();
            db.UsuarioArmazens.RemoveRange(existentes);

            var novos = _vinculos
                .Where(v => v.Vinculado)
                .Select(v => new UsuarioArmazem
                {
                    UsuarioId = _usuarioArmazensId,
                    ArmazemId = v.ArmazemId,
                    Role = v.Role
                });
            db.UsuarioArmazens.AddRange(novos);

            await db.SaveChangesAsync();
            
            _showArmazensModal = false;
            ToastService.Success($"Armazéns de \"{_usuarioArmazensNome}\" atualizados com sucesso!");
            await CarregarDados();
        }
        catch (Exception ex)
        {
            ToastService.Error($"Erro ao salvar armazéns: {ex.Message}");
        }
        finally
        {
            _salvandoArmazens = false;
        }
    }

    // === CLASSES DE MODELO ===
    private class VinculoItem
    {
        public int ArmazemId { get; set; }
        public string ArmazemNome { get; set; } = string.Empty;
        public bool Vinculado { get; set; }
        public string Role { get; set; } = "Operador";
    }

    public void Dispose()
    {
        TabService.OnTabsChanged -= HandleTabFocus;
    }

    private async Task Excluir(ApplicationUser usuario)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Deseja realmente excluir o usuário \"{usuario.Nome}\"? Esta ação não pode ser desfeita.");
        if (!confirmado) return;

        try
        {
            var user = await UserManager.FindByIdAsync(usuario.Id);
            if (user is not null)
            {
                // Remover vínculos de armazéns primeiro
                await using var db = await DbFactory.CreateDbContextAsync();
                var vinculos = db.UsuarioArmazens.Where(ua => ua.UsuarioId == usuario.Id);
                db.UsuarioArmazens.RemoveRange(vinculos);
                await db.SaveChangesAsync();

                var result = await UserManager.DeleteAsync(user);
                if (result.Succeeded)
                {
                    ToastService.Success($"Usuário \"{usuario.Nome}\" excluído com sucesso!");
                    await CarregarDados();
                }
                else
                {
                    ToastService.Error($"Erro ao excluir usuário: {string.Join(", ", result.Errors.Select(e => e.Description))}");
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Error($"Erro ao excluir usuário: {ex.Message}");
        }
    }
}
