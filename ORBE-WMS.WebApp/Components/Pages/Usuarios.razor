@page "/admin/usuarios"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ORBE_WMS.WebApp.Data

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Usuários - ORBE WMS</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Usuários</h4>
    <button class="btn btn-primary" @onclick="CriarUsuario">
        <i class="bi bi-person-plus-fill me-1"></i> Novo Usuário
    </button>
</div>

@if (_carregandoPrincipal)
{
    <div class="progress" style="height: 3px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex align-items-center">
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar usuário..." @bind="_searchString" @bind:event="oninput" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Armazéns</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (UsuariosFiltrados.Any())
                    {
                        @foreach (var context in UsuariosFiltrados)
                        {
                            <tr>
                                <td>@context.Nome</td>
                                <td>@context.Email</td>
                                <td>
                                    @if (context.Ativo)
                                    {
                                        <span class="badge bg-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inativo</span>
                                    }
                                </td>
                                <td>
                                    @if (context.Armazens.Any())
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var ua in context.Armazens)
                                            {
                                                <span class="badge bg-info text-dark">@ua.Armazem.Nome (@ua.Role)</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Nenhum</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" title="Editar" @onclick="() => EditarUsuario(context)">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary me-1" title="Gerenciar Armazéns" @onclick="() => GerenciarArmazens(context)">
                                        <i class="bi bi-building"></i>
                                    </button>
                                    <button class="btn btn-sm @(context.Ativo ? "btn-outline-danger" : "btn-outline-success")" 
                                            title="@(context.Ativo ? "Desativar" : "Ativar")"
                                            @onclick="() => ToggleAtivo(context)">
                                        <i class="bi @(context.Ativo ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Nenhum usuário encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- USER MODAL (Create / Edit) -->
@if (_showUserModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person me-2"></i>
                        @(_isEditando ? "Editar Usuário" : "Novo Usuário")
                    </h5>
                    <button type="button" class="btn-close" @onclick="FecharUserModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_erroUser))
                    {
                        <div class="alert alert-danger py-2" role="alert">@_erroUser</div>
                    }

                    <EditForm Model="_userModel" OnValidSubmit="SalvarUsuario">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label">Nome Completo *</label>
                            <InputText @bind-Value="_userModel.Nome" class="form-control" />
                            <ValidationMessage For="() => _userModel.Nome" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email *</label>
                            <InputText @bind-Value="_userModel.Email" class="form-control" type="email" disabled="@_isEditando" />
                            <ValidationMessage For="() => _userModel.Email" class="text-danger small" />
                        </div>

                        @if (!_isEditando)
                        {
                            <div class="mb-3">
                                <label class="form-label">Senha *</label>
                                <InputText @bind-Value="_userModel.Senha" class="form-control" type="password" />
                                <ValidationMessage For="() => _userModel.Senha" class="text-danger small" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Confirmar Senha *</label>
                                <InputText @bind-Value="_userModel.ConfirmarSenha" class="form-control" type="password" />
                                <ValidationMessage For="() => _userModel.ConfirmarSenha" class="text-danger small" />
                                @if (!string.IsNullOrEmpty(ValidarConfirmacao(_userModel.ConfirmarSenha)))
                                {
                                    <div class="text-danger small mt-1">@ValidarConfirmacao(_userModel.ConfirmarSenha)</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="mb-3 form-check form-switch">
                                <InputCheckbox @bind-Value="_userModel.Ativo" class="form-check-input" id="checkAtivo" />
                                <label class="form-check-label" for="checkAtivo">Usuário Ativo</label>
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-light" @onclick="FecharUserModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary" disabled="@_salvandoUser">
                                @if (_salvandoUser)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                Salvar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- WAREHOUSES MANAGEMENT MODAL -->
@if (_showArmazensModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-building me-2"></i>
                        Armazéns de @_usuarioArmazensNome
                    </h5>
                    <button type="button" class="btn-close" @onclick="FecharArmazensModal"></button>
                </div>
                <div class="modal-body">
                    @if (_carregandoArmazens)
                    {
                        <div class="progress" style="height: 3px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
                        </div>
                    }
                    else if (!_vinculos.Any())
                    {
                        <div class="alert alert-info py-2" role="alert">
                            Nenhum armazém cadastrado no sistema. Crie um armazém antes de vincular usuários.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-3">Selecione os armazéns e defina o papel do usuário em cada um.</p>

                        <div class="list-group">
                            @foreach (var item in _vinculos)
                            {
                                <div class="list-group-item d-flex align-items-center justify-content-between p-3">
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox" @bind="item.Vinculado" id="chk_@item.ArmazemId">
                                        <label class="form-check-label fw-bold" for="chk_@item.ArmazemId">
                                            @item.ArmazemNome
                                        </label>
                                    </div>
                                    <div style="width: 200px;">
                                        <select class="form-select form-select-sm" @bind="item.Role" disabled="@(!item.Vinculado)">
                                            <option value="Gerente">Gerente</option>
                                            <option value="Operador">Operador</option>
                                        </select>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="FecharArmazensModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="SalvarArmazens" disabled="@(_salvandoArmazens || _carregandoArmazens)">
                        @if (_salvandoArmazens)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ApplicationUser> _usuarios = [];
    private bool _carregandoPrincipal = true;
    private string _searchString = "";

    // MODAL STATE - USER
    private bool _showUserModal = false;
    private bool _isEditando = false;
    private bool _salvandoUser = false;
    private string? _usuarioIdEditando;
    private string? _erroUser;
    private UsuarioModel _userModel = new();

    // MODAL STATE - WAREHOUSE MANAGEMENT
    private bool _showArmazensModal = false;
    private string _usuarioArmazensId = "";
    private string _usuarioArmazensNome = "";
    private bool _carregandoArmazens = false;
    private bool _salvandoArmazens = false;
    private List<VinculoItem> _vinculos = [];

    private IEnumerable<ApplicationUser> UsuariosFiltrados => _usuarios.Where(x =>
        string.IsNullOrWhiteSpace(_searchString) ||
        x.Nome.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        (x.Email != null && x.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
    );

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        _carregandoPrincipal = true;
        Db.ChangeTracker.Clear();
        _usuarios = await Db.Users
            .AsNoTracking()
            .Include(u => u.Armazens)
                .ThenInclude(ua => ua.Armazem)
            .OrderBy(u => u.Nome)
            .ToListAsync();
        _carregandoPrincipal = false;
    }

    // === MÉTODOS DE USUÁRIO ===
    private void CriarUsuario()
    {
        _isEditando = false;
        _usuarioIdEditando = null;
        _userModel = new UsuarioModel();
        _erroUser = null;
        _showUserModal = true;
    }

    private async Task EditarUsuario(ApplicationUser usuario)
    {
        _isEditando = true;
        _usuarioIdEditando = usuario.Id;
        _erroUser = null;

        var user = await UserManager.FindByIdAsync(usuario.Id);
        if (user is not null)
        {
            _userModel = new UsuarioModel
            {
                Nome = user.Nome,
                Email = user.Email ?? string.Empty,
                Ativo = user.Ativo
            };
            _showUserModal = true;
        }
    }

    private void FecharUserModal()
    {
        _showUserModal = false;
    }

    private string? ValidarConfirmacao(string confirmacao)
    {
        if (!_isEditando && confirmacao != _userModel.Senha)
            return "As senhas não coincidem";
        return null;
    }

    private async Task SalvarUsuario()
    {
        if (!_isEditando && _userModel.Senha != _userModel.ConfirmarSenha)
        {
            return;
        }

        _salvandoUser = true;
        _erroUser = null;

        try
        {
            if (_isEditando)
            {
                var user = await UserManager.FindByIdAsync(_usuarioIdEditando!);
                if (user is not null)
                {
                    user.Nome = _userModel.Nome;
                    user.Ativo = _userModel.Ativo;
                    var result = await UserManager.UpdateAsync(user);
                    if (!result.Succeeded)
                    {
                        _erroUser = string.Join(", ", result.Errors.Select(e => e.Description));
                        return;
                    }
                }
            }
            else
            {
                var user = new ApplicationUser
                {
                    UserName = _userModel.Email,
                    Email = _userModel.Email,
                    Nome = _userModel.Nome,
                    Ativo = true,
                    EmailConfirmed = true
                };

                var result = await UserManager.CreateAsync(user, _userModel.Senha);
                if (!result.Succeeded)
                {
                    _erroUser = string.Join(", ", result.Errors.Select(e => e.Description));
                    return;
                }
            }

            _showUserModal = false;
            await CarregarDados();
        }
        finally
        {
            _salvandoUser = false;
        }
    }

    private async Task ToggleAtivo(ApplicationUser usuario)
    {
        var user = await UserManager.FindByIdAsync(usuario.Id);
        if (user is not null)
        {
            user.Ativo = !user.Ativo;
            await UserManager.UpdateAsync(user);
            await CarregarDados();
        }
    }

    // === MÉTODOS DE ARMAZÉNS DO USUÁRIO ===
    private async Task GerenciarArmazens(ApplicationUser usuario)
    {
        _usuarioArmazensId = usuario.Id;
        _usuarioArmazensNome = usuario.Nome;
        _showArmazensModal = true;
        _carregandoArmazens = true;

        var armazensAll = await Db.Armazens.AsNoTracking().Where(a => a.Ativo).OrderBy(a => a.Nome).ToListAsync();
        var vinculosExistentes = await Db.UsuarioArmazens.AsNoTracking()
            .Where(ua => ua.UsuarioId == usuario.Id)
            .ToListAsync();

        _vinculos = armazensAll.Select(a =>
        {
            var existente = vinculosExistentes.FirstOrDefault(v => v.ArmazemId == a.Id);
            return new VinculoItem
            {
                ArmazemId = a.Id,
                ArmazemNome = a.Nome,
                Vinculado = existente is not null,
                Role = existente?.Role ?? "Operador"
            };
        }).ToList();

        _carregandoArmazens = false;
    }

    private void FecharArmazensModal()
    {
        _showArmazensModal = false;
    }

    private async Task SalvarArmazens()
    {
        _salvandoArmazens = true;
        try
        {
            // Remove todos os vínculos existentes
            var existentes = await Db.UsuarioArmazens
                .Where(ua => ua.UsuarioId == _usuarioArmazensId)
                .ToListAsync();
            Db.UsuarioArmazens.RemoveRange(existentes);

            // Adiciona os novos vínculos selecionados
            var novos = _vinculos
                .Where(v => v.Vinculado)
                .Select(v => new UsuarioArmazem
                {
                    UsuarioId = _usuarioArmazensId,
                    ArmazemId = v.ArmazemId,
                    Role = v.Role
                });
            Db.UsuarioArmazens.AddRange(novos);

            await Db.SaveChangesAsync();
            Db.ChangeTracker.Clear();
            
            _showArmazensModal = false;
            await CarregarDados();
        }
        finally
        {
            _salvandoArmazens = false;
        }
    }

    // === CLASSES DE MODELO ===
    private class UsuarioModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Nome é obrigatório")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Nome { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email é obrigatório")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = string.Empty;

        public string Senha { get; set; } = string.Empty;
        public string ConfirmarSenha { get; set; } = string.Empty;
        public bool Ativo { get; set; } = true;
    }

    private class VinculoItem
    {
        public int ArmazemId { get; set; }
        public string ArmazemNome { get; set; } = string.Empty;
        public bool Vinculado { get; set; }
        public string Role { get; set; } = "Operador";
    }
}
