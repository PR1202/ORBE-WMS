@page "/Error"
@using System.Diagnostics

<PageTitle>Erro - ORBE WMS</PageTitle>

<div class="d-flex flex-column align-items-center justify-content-center py-5">
    <div class="text-center">
        <div class="mb-4" style="font-size: 4rem; color: #dc3545;">
            <i class="bi bi-x-circle"></i>
        </div>
        <h1 class="display-6 fw-bold text-dark mb-2">Ocorreu um erro</h1>
        <p class="text-muted mb-3" style="max-width: 460px; margin: 0 auto;">
            Um erro inesperado ocorreu ao processar sua solicitação. 
            Por favor, tente novamente ou entre em contato com o administrador.
        </p>

        @if (ShowRequestId)
        {
            <p class="small text-muted mb-3">
                <strong>ID da Requisição:</strong> <code>@RequestId</code>
            </p>
        }

        <a href="/" class="btn btn-primary px-4 py-2">
            <i class="bi bi-house-door me-2"></i>Voltar ao Dashboard
        </a>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
