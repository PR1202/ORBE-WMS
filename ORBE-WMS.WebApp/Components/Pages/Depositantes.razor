@* Componente renderizado dentro do sistema de abas *@
@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ORBE_WMS.Application.DTOs
@using ORBE_WMS.Application.Services
@using ORBE_WMS.WebApp.Services

@inject ArmazemAppService ArmazemService
@inject DepositanteAppService DepositanteService
@inject AuthenticationStateProvider AuthStateProvider
@inject TabService TabService
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Depositantes - ORBE WMS</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Depositantes</h4>
    @if (_armazens.Any())
    {
        <button class="btn btn-primary" @onclick="CriarDepositante">
            <i class="bi bi-plus-lg me-1"></i> Novo Depositante
        </button>
    }
</div>

@if (_armazens.Count > 1)
{
    <div class="mb-4" style="max-width: 350px;">
        <label class="form-label">Filtrar por Armazém</label>
        <select class="form-select" @onchange="OnFiltroChanged">
            <option value="">Todos</option>
            @foreach (var a in _armazens)
            {
                <option value="@a.Id" selected="@(_armazemFiltro == a.Id)">@a.Nome</option>
            }
        </select>
    </div>
}

@if (_carregando)
{
    <div class="progress" style="height: 3px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
    </div>
}
else if (!_armazens.Any())
{
    <div class="alert alert-info mt-4" role="alert">
        Você não possui acesso a nenhum armazém. Solicite ao administrador que vincule sua conta a um armazém.
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex align-items-center">
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar depositante..." @bind="_searchString" @bind:event="oninput" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>CNPJ</th>
                        <th>Cód. Externo</th>
                        <th>Armazém</th>
                        <th>Status</th>
                        <th>Criado em</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (DepositantesFiltradosEBusca.Any())
                    {
                        @foreach (var context in DepositantesFiltradosEBusca)
                        {
                            <tr>
                                <td>@context.Nome</td>
                                <td>@context.CNPJ</td>
                                <td>@context.CodigoExterno</td>
                                <td>@context.ArmazemNome</td>
                                <td>
                                    @if (context.Ativo)
                                    {
                                        <span class="badge bg-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inativo</span>
                                    }
                                </td>
                                <td>@context.DataCriacao.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" title="Editar" @onclick="() => EditarDepositante(context)">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="btn btn-sm @(context.Ativo ? "btn-outline-danger" : "btn-outline-success") me-1" 
                                            title="@(context.Ativo ? "Desativar" : "Ativar")"
                                            @onclick="() => ToggleAtivo(context)">
                                        <i class="bi @(context.Ativo ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" title="Excluir" @onclick="() => Excluir(context)">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Nenhum depositante encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<DepositanteDto> _depositantes = [];
    private List<ArmazemDto> _armazens = [];
    private bool _carregando = true;
    private bool _isAdmin;
    private string? _userId;
    private string _searchString = "";
    private int? _armazemFiltro;
    private bool _wasActive = true;

    private IEnumerable<DepositanteDto> DepositantesFiltradosEBusca => _depositantes
        .Where(d => !_armazemFiltro.HasValue || d.ArmazemId == _armazemFiltro.Value)
        .Where(x =>
            string.IsNullOrWhiteSpace(_searchString) ||
            x.Nome.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            (x.CNPJ != null && x.CNPJ.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
            (x.CodigoExterno != null && x.CodigoExterno.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
            x.ArmazemNome.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
        );

    protected override async Task OnInitializedAsync()
    {
        TabService.OnTabsChanged += HandleTabFocus;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        _isAdmin = user.IsInRole("Admin");

        await CarregarDados();
    }

    private async void HandleTabFocus()
    {
        var isActive = TabService.ActiveTab?.ComponentType == typeof(Depositantes);
        if (isActive && !_wasActive)
        {
            await InvokeAsync(async () =>
            {
                await CarregarDados();
                StateHasChanged();
            });
        }
        _wasActive = isActive;
    }

    public void Dispose()
    {
        TabService.OnTabsChanged -= HandleTabFocus;
    }

    private async Task CarregarDados()
    {
        _carregando = true;

        if (_isAdmin)
        {
            _armazens = await ArmazemService.ObterAtivosAsync();
            _depositantes = await DepositanteService.ObterTodosAsync();
        }
        else if (_userId is not null)
        {
            _armazens = await ArmazemService.ObterAtivosPorUsuarioAsync(_userId);
            var armazemIds = _armazens.Select(a => a.Id).ToList();
            _depositantes = await DepositanteService.ObterPorArmazensAsync(armazemIds);
        }

        _carregando = false;
    }

    private void OnFiltroChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            _armazemFiltro = id;
        }
        else
        {
            _armazemFiltro = null;
        }
    }

    private void CriarDepositante()
    {
        TabService.OpenFormTab("✚ Novo Depositante", "bi-plus-circle", typeof(FormDepositante), new Dictionary<string, object>
        {
            ["DepositanteId"] = 0
        });
    }

    private void EditarDepositante(DepositanteDto depositante)
    {
        TabService.OpenFormTab($"✏ Editar: {depositante.Nome}", "bi-pencil-square", typeof(FormDepositante), new Dictionary<string, object>
        {
            ["DepositanteId"] = depositante.Id
        });
    }

    private async Task ToggleAtivo(DepositanteDto depositante)
    {
        try
        {
            var novoStatus = await DepositanteService.ToggleAtivoAsync(depositante.Id);
            var status = novoStatus ? "ativado" : "desativado";
            ToastService.Success($"Depositante \"{depositante.Nome}\" {status} com sucesso!");
            await CarregarDados();
        }
        catch (Exception ex)
        {
            ToastService.Error($"Erro ao alterar status: {ex.Message}");
        }
    }

    private async Task Excluir(DepositanteDto depositante)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Deseja realmente excluir o depositante \"{depositante.Nome}\"?");
        if (!confirmado) return;

        try
        {
            await DepositanteService.RemoverAsync(depositante.Id);
            ToastService.Success($"Depositante \"{depositante.Nome}\" excluído com sucesso!");
            await CarregarDados();
        }
        catch (Exception ex)
        {
            ToastService.Error($"Erro ao excluir depositante: {ex.Message}");
        }
    }
}
