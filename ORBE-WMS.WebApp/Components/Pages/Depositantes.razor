@page "/depositantes"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ORBE_WMS.WebApp.Data
@using ORBE_WMS.WebApp.Components.Dialogs

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Depositantes - ORBE WMS</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Depositantes</MudText>
    <MudSpacer />
    @if (_armazens.Any())
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="CriarDepositante">
            Novo Depositante
        </MudButton>
    }
</MudStack>

@if (_armazens.Count > 1)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="3">
        <MudSelect T="int?" Value="_armazemFiltro" Label="Filtrar por Armazém"
                   Variant="Variant.Outlined" Dense="true" Clearable="true"
                   Style="max-width: 350px;"
                   ValueChanged="OnFiltroChanged">
            @foreach (var a in _armazens)
            {
                <MudSelectItem T="int?" Value="@((int?)a.Id)">@a.Nome</MudSelectItem>
            }
        </MudSelect>
    </MudStack>
}

@if (_carregando)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_armazens.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-4">
        Você não possui acesso a nenhum armazém. Solicite ao administrador que vincule sua conta a um armazém.
    </MudAlert>
}
else
{
    <MudDataGrid Items="@_depositantesFiltrados" Dense="true" Hover="true" Striped="true" Bordered="true"
                 FixedHeader="true" Height="calc(100vh - 300px)"
                 Filterable="true" FilterMode="DataGridFilterMode.Simple"
                 QuickFilter="@_quickFilter">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" Placeholder="Buscar depositante..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" Immediate="true" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Nome" Title="Nome" />
            <PropertyColumn Property="x => x.CNPJ" Title="CNPJ" />
            <PropertyColumn Property="x => x.CodigoExterno" Title="Cód. Externo" />
            <PropertyColumn Property="x => x.Armazem.Nome" Title="Armazém" />
            <TemplateColumn Title="Status" Sortable="false" Filterable="false">
                <CellTemplate>
                    @if (context.Item.Ativo)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Ativo</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">Inativo</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.DataCriacao" Title="Criado em" Format="dd/MM/yyyy" />
            <TemplateColumn Title="Ações" Sortable="false" Filterable="false">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1">
                        <MudTooltip Text="Editar">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => EditarDepositante(context.Item)" />
                        </MudTooltip>
                        <MudTooltip Text="@(context.Item.Ativo ? "Desativar" : "Ativar")">
                            <MudIconButton Icon="@(context.Item.Ativo ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                           Size="Size.Small"
                                           Color="@(context.Item.Ativo ? Color.Success : Color.Default)"
                                           OnClick="() => ToggleAtivo(context.Item)" />
                        </MudTooltip>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText>Nenhum depositante encontrado.</MudText>
        </NoRecordsContent>
    </MudDataGrid>
}

@code {
    private List<Depositante> _depositantes = [];
    private List<Armazem> _armazens = [];
    private List<int> _armazemIdsPermitidos = [];
    private bool _carregando = true;
    private bool _isAdmin;
    private string? _userId;
    private string? _searchString;
    private int? _armazemFiltro;

    private IEnumerable<Depositante> _depositantesFiltrados =>
        _armazemFiltro.HasValue
            ? _depositantes.Where(d => d.ArmazemId == _armazemFiltro.Value)
            : _depositantes;

    private Func<Depositante, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if (x.Nome.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.CNPJ is not null && x.CNPJ.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.CodigoExterno is not null && x.CodigoExterno.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.Armazem?.Nome.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        return false;
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        _isAdmin = user.IsInRole("Admin");

        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        _carregando = true;

        if (_isAdmin)
        {
            // Admin vê todos os armazéns e depositantes
            _armazens = await Db.Armazens.AsNoTracking().Where(a => a.Ativo).OrderBy(a => a.Nome).ToListAsync();
            _depositantes = await Db.Depositantes.AsNoTracking().Include(d => d.Armazem).OrderBy(d => d.Nome).ToListAsync();
        }
        else
        {
            // Usuário comum: apenas armazéns vinculados
            _armazemIdsPermitidos = await Db.UsuarioArmazens.AsNoTracking()
                .Where(ua => ua.UsuarioId == _userId)
                .Select(ua => ua.ArmazemId)
                .ToListAsync();

            _armazens = await Db.Armazens.AsNoTracking()
                .Where(a => a.Ativo && _armazemIdsPermitidos.Contains(a.Id))
                .OrderBy(a => a.Nome)
                .ToListAsync();

            _depositantes = await Db.Depositantes.AsNoTracking()
                .Include(d => d.Armazem)
                .Where(d => _armazemIdsPermitidos.Contains(d.ArmazemId))
                .OrderBy(d => d.Nome)
                .ToListAsync();
        }

        _carregando = false;
    }

    private void OnFiltroChanged(int? value)
    {
        _armazemFiltro = value;
    }

    private async Task CriarDepositante()
    {
        var parameters = new DialogParameters
        {
            { nameof(DepositanteDialog.ArmazemIdsPermitidos), _armazens.Select(a => a.Id).ToList() }
        };
        if (_armazemFiltro.HasValue)
        {
            parameters.Add(nameof(DepositanteDialog.ArmazemIdPadrao), _armazemFiltro.Value);
        }

        var dialog = await DialogService.ShowAsync<DepositanteDialog>("Novo Depositante", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await CarregarDados();
            Snackbar.Add("Depositante criado com sucesso!", Severity.Success);
        }
    }

    private async Task EditarDepositante(Depositante depositante)
    {
        var parameters = new DialogParameters
        {
            { nameof(DepositanteDialog.DepositanteId), depositante.Id },
            { nameof(DepositanteDialog.ArmazemIdsPermitidos), _armazens.Select(a => a.Id).ToList() }
        };

        var dialog = await DialogService.ShowAsync<DepositanteDialog>("Editar Depositante", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await CarregarDados();
            Snackbar.Add("Depositante atualizado com sucesso!", Severity.Success);
        }
    }

    private async Task ToggleAtivo(Depositante depositante)
    {
        var acao = depositante.Ativo ? "desativar" : "ativar";
        var confirmed = await DialogService.ShowMessageBox(
            "Confirmar",
            $"Deseja {acao} o depositante \"{depositante.Nome}\"?",
            yesText: "Sim", cancelText: "Cancelar");

        if (confirmed == true)
        {
            var entity = await Db.Depositantes.FindAsync(depositante.Id);
            if (entity is not null)
            {
                entity.Ativo = !entity.Ativo;
                await Db.SaveChangesAsync();
                Db.ChangeTracker.Clear();
                await CarregarDados();
                Snackbar.Add($"Depositante {(entity.Ativo ? "ativado" : "desativado")} com sucesso!", Severity.Success);
            }
        }
    }
}
