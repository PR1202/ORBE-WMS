@* Formulário de Armazém — renderizado como aba *@

@using Microsoft.EntityFrameworkCore
@using ORBE_WMS.WebApp.Data
@using ORBE_WMS.WebApp.Services

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject TabService TabService
@inject ToastService ToastService

<PageTitle>@(_isEdit ? $"Editar: {_model.Nome}" : "Novo Armazém") - ORBE WMS</PageTitle>

<div class="form-page-container">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-title">
                <i class="bi @(_isEdit ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                @(_isEdit ? $"Editar Armazém" : "Novo Armazém")
            </div>
            @if (_isEdit)
            {
                <span class="badge bg-info text-dark">ID: @ArmazemId</span>
            }
        </div>

        <div class="form-card-body">
            <EditForm Model="_model" OnValidSubmit="Salvar">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
                        <InputText @bind-Value="_model.Nome" class="form-control form-control-lg" placeholder="Nome do armazém" />
                        <ValidationMessage For="() => _model.Nome" class="text-danger small mt-1" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-semibold">CNPJ</label>
                        <InputText @bind-Value="_model.CNPJ" class="form-control form-control-lg" placeholder="00.000.000/0000-00" />
                        <ValidationMessage For="() => _model.CNPJ" class="text-danger small mt-1" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Endereço</label>
                    <InputTextArea @bind-Value="_model.Endereco" class="form-control" rows="3" placeholder="Endereço completo do armazém" />
                    <ValidationMessage For="() => _model.Endereco" class="text-danger small mt-1" />
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-light px-4" @onclick="Cancelar">
                        <i class="bi bi-x-lg me-1"></i> Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary px-4" disabled="@_salvando">
                        @if (_salvando)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i> Salvar
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? ArmazemId { get; set; }
    [Parameter] public Guid TabId { get; set; }

    private bool _isEdit;
    private bool _salvando;
    private ArmazemModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        _isEdit = ArmazemId.HasValue && ArmazemId.Value > 0;

        if (_isEdit)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var armazem = await db.Armazens.FindAsync(ArmazemId!.Value);
            if (armazem is not null)
            {
                _model = new ArmazemModel
                {
                    Nome = armazem.Nome,
                    CNPJ = armazem.CNPJ,
                    Endereco = armazem.Endereco
                };
            }
        }
    }

    private async Task Salvar()
    {
        _salvando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (_isEdit)
            {
                var armazem = await db.Armazens.FindAsync(ArmazemId!.Value);
                if (armazem is not null)
                {
                    armazem.Nome = _model.Nome;
                    armazem.CNPJ = _model.CNPJ;
                    armazem.Endereco = _model.Endereco;
                    await db.SaveChangesAsync();
                    ToastService.Success($"Armazém \"{_model.Nome}\" atualizado com sucesso!");
                }
            }
            else
            {
                var armazem = new Armazem
                {
                    Nome = _model.Nome,
                    CNPJ = _model.CNPJ,
                    Endereco = _model.Endereco
                };
                db.Armazens.Add(armazem);
                await db.SaveChangesAsync();
                ToastService.Success($"Armazém \"{_model.Nome}\" criado com sucesso!");
            }

            TabService.CloseFormAndActivateListing(TabId, typeof(Armazens));
        }
        catch (Exception ex)
        {
            ToastService.Error($"Erro ao salvar armazém: {ex.Message}");
        }
        finally
        {
            _salvando = false;
        }
    }

    private void Cancelar()
    {
        TabService.CloseTab(TabId);
    }

    private class ArmazemModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Nome é obrigatório")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Nome { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.MaxLength(18)]
        public string? CNPJ { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(500)]
        public string? Endereco { get; set; }
    }
}
