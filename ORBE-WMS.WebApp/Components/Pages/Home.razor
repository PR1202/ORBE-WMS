@* Componente renderizado dentro do sistema de abas *@

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ORBE_WMS.Application.DTOs
@using ORBE_WMS.Application.Services
@using ORBE_WMS.WebApp.Services

@inject DashboardAppService DashboardService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject TabService TabService

<PageTitle>Dashboard - ORBE WMS</PageTitle>

@if (_carregando)
{
    <div class="progress" style="height: 3px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1" style="font-size: 1.4rem;">Bem-vindo, @_dashboard.NomeUsuario</h4>
            <span class="text-muted" style="font-size: 0.8rem;">
                @DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))
            </span>
        </div>
        @if (_dashboard.IsAdmin)
        {
            <div>
                <span class="badge bg-primary px-3 py-2 rounded-pill" style="font-size: 0.7rem;">
                    <i class="bi bi-shield-fill me-1"></i> Administrador
                </span>
            </div>
        }
    </div>

    <!-- CARDS KPI -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-md-3">
            <div class="kpi-card kpi-primary">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon">
                        <i class="bi bi-building-add"></i>
                    </div>
                    <div>
                        <div class="kpi-value">@_dashboard.TotalArmazens</div>
                        <div class="kpi-label">@(_dashboard.IsAdmin ? "Armazéns" : "Meus Armazéns")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="kpi-card kpi-success">
                <div class="d-flex align-items-center gap-3">
                    <div class="kpi-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <div>
                        <div class="kpi-value">@_dashboard.TotalDepositantes</div>
                        <div class="kpi-label">Depositantes</div>
                    </div>
                </div>
            </div>
        </div>

        @if (_dashboard.IsAdmin)
        {
            <div class="col-12 col-sm-6 col-md-3">
                <div class="kpi-card kpi-info">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <div class="kpi-value">@_dashboard.TotalUsuarios</div>
                            <div class="kpi-label">Usuários</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <div class="kpi-card kpi-warning">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div>
                            <div class="kpi-value">@_dashboard.DepositantesInativos</div>
                            <div class="kpi-label">Dep. Inativos</div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="col-12 col-sm-6 col-md-3">
                <div class="kpi-card kpi-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <div>
                            <div class="kpi-value" style="font-size: 1.1rem;">@_dashboard.MeuPapel</div>
                            <div class="kpi-label">Meu Papel</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-4">
        <!-- MEUS ARMAZÉNS -->
        <div class="col-12 @(_dashboard.IsAdmin ? "col-md-6" : "col-md-12")">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3" style="font-size: 0.95rem; color: var(--orbe-primary);">
                        <i class="bi bi-building-add me-2" style="color: var(--orbe-accent);"></i>@(_dashboard.IsAdmin ? "Armazéns Recentes" : "Meus Armazéns")
                    </h5>

                    @if (_dashboard.ArmazensRecentes.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var a in _dashboard.ArmazensRecentes)
                            {
                                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-chevron-right me-3" style="color: var(--orbe-accent); font-size: 0.7rem;"></i>
                                        <div>
                                            <p class="mb-0 fw-semibold" style="font-size: 0.875rem;">@a.Nome</p>
                                            @if (a.CNPJ is not null)
                                            {
                                                <small class="text-muted" style="font-size: 0.75rem;">@a.CNPJ</small>
                                            }
                                        </div>
                                    </div>
                                    <span class="badge @(a.Ativo ? "bg-success" : "bg-secondary") rounded-pill">
                                        @(a.Ativo ? "Ativo" : "Inativo")
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info py-2 mt-2">
                            Nenhum armazém vinculado. Solicite ao administrador.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ACESSO RÁPIDO -->
        <div class="col-12 col-md-6">
            @if (_dashboard.IsAdmin || _dashboard.ArmazensRecentes.Any())
            {
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-3" style="font-size: 0.95rem; color: var(--orbe-text-secondary);">
                            <i class="bi bi-lightning-charge-fill me-2" style="color: var(--orbe-accent);"></i>Acesso Rápido
                        </h5>

                        <div class="row g-2">
                            @if (_dashboard.IsAdmin)
                            {
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirArmazens">
                                        <i class="bi bi-plus-lg"></i> Novo Armazém
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirUsuarios">
                                        <i class="bi bi-person-plus-fill"></i> Novo Usuário
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirDepositantes">
                                        <i class="bi bi-building"></i> Depositantes
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirUsuarios">
                                        <i class="bi bi-people-fill"></i> Usuários
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirDepositantes">
                                        <i class="bi bi-building"></i> Depositantes
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirRecebimento">
                                        <i class="bi bi-box-arrow-in-right"></i> Recebimento
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirEstoque">
                                        <i class="bi bi-box"></i> Estoque
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="quick-access-btn w-100" @onclick="AbrirExpedicao">
                                        <i class="bi bi-truck"></i> Expedição
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _carregando = true;
    private DashboardDto _dashboard = new();

    // Abrir abas via acesso rápido
    private void AbrirArmazens() => TabService.OpenTab("Armazéns", "bi-building-add", typeof(Armazens));
    private void AbrirDepositantes() => TabService.OpenTab("Depositantes", "bi-building", typeof(Depositantes));
    private void AbrirUsuarios() => TabService.OpenTab("Usuários", "bi-people-fill", typeof(Usuarios));
    private void AbrirRecebimento() => TabService.OpenTab("Recebimento", "bi-box-arrow-in-right", typeof(Recebimento));
    private void AbrirEstoque() => TabService.OpenTab("Estoque", "bi-box", typeof(Estoque));
    private void AbrirExpedicao() => TabService.OpenTab("Expedição", "bi-truck", typeof(Expedicao));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        var isAdmin = user.IsInRole("Admin");

        if (userId is not null)
        {
            _dashboard = isAdmin
                ? await DashboardService.ObterDashboardAdminAsync(userId)
                : await DashboardService.ObterDashboardUsuarioAsync(userId);
        }

        _carregando = false;
    }
}
