@* Componente renderizado dentro do sistema de abas *@

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using ORBE_WMS.WebApp.Data
@using ORBE_WMS.WebApp.Services

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject TabService TabService

<PageTitle>Dashboard - ORBE WMS</PageTitle>

@if (_carregando)
{
    <div class="progress" style="height: 3px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1">Bem-vindo, @_nomeUsuario</h4>
            <span class="text-muted small">
                @DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"))
            </span>
        </div>
        @if (_isAdmin)
        {
            <div>
                <span class="badge bg-primary px-3 py-2 rounded-pill">
                    <i class="bi bi-shield-fill me-1"></i> Administrador
                </span>
            </div>
        }
    </div>

    <!-- CARDS KPI -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-primary h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary me-3">
                            <i class="bi bi-building-add fs-4"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-0">@_totalArmazens</h4>
                            <span class="text-muted small">@(_isAdmin ? "Armazéns" : "Meus Armazéns")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-success h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success me-3">
                            <i class="bi bi-building fs-4"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-0">@_totalDepositantes</h4>
                            <span class="text-muted small">Depositantes</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (_isAdmin)
        {
            <div class="col-12 col-sm-6 col-md-3">
                <div class="card shadow-sm border-0 border-start border-4 border-info h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info me-3">
                                <i class="bi bi-people-fill fs-4"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0">@_totalUsuarios</h4>
                                <span class="text-muted small">Usuários</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-md-3">
                <div class="card shadow-sm border-0 border-start border-4 border-warning h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning me-3">
                                <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0">@_depositantesInativos</h4>
                                <span class="text-muted small">Dep. Inativos</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="col-12 col-sm-6 col-md-3">
                <div class="card shadow-sm border-0 border-start border-4 border-info h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info me-3">
                                <i class="bi bi-person-badge fs-4"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0">@_meuPapel</h4>
                                <span class="text-muted small">Meu Papel</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-4">
        <!-- MEUS ARMAZÉNS -->
        <div class="col-12 @(_isAdmin ? "col-md-6" : "col-md-12")">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title text-primary mb-3">
                        <i class="bi bi-building-add me-2"></i>@(_isAdmin ? "Armazéns Recentes" : "Meus Armazéns")
                    </h5>

                    @if (_armazens.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var a in _armazens)
                            {
                                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-chevron-right text-primary me-3"></i>
                                        <div>
                                            <p class="mb-0 fw-semibold">@a.Nome</p>
                                            @if (a.CNPJ is not null)
                                            {
                                                <small class="text-muted">@a.CNPJ</small>
                                            }
                                        </div>
                                    </div>
                                    <span class="badge @(a.Ativo ? "bg-success" : "bg-secondary") rounded-pill">
                                        @(a.Ativo ? "Ativo" : "Inativo")
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info py-2 mt-2">
                            Nenhum armazém vinculado. Solicite ao administrador.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ACESSO RÁPIDO -->
        <div class="col-12 col-md-6">
            @if (_isAdmin || _armazens.Any())
            {
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title text-secondary mb-3">
                            <i class="bi bi-lightning-charge-fill me-2"></i>Acesso Rápido
                        </h5>

                        <div class="row g-2">
                            @if (_isAdmin)
                            {
                                <div class="col-6">
                                    <button class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirArmazens">
                                        <i class="bi bi-plus-lg fs-4 mb-1"></i> Novo Armazém
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-secondary w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirUsuarios">
                                        <i class="bi bi-person-plus-fill fs-4 mb-1"></i> Novo Usuário
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirDepositantes">
                                        <i class="bi bi-building fs-4 mb-1"></i> Depositantes
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-info w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirUsuarios">
                                        <i class="bi bi-people-fill fs-4 mb-1"></i> Usuários
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="col-6">
                                    <button class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirDepositantes">
                                        <i class="bi bi-building fs-4 mb-1"></i> Depositantes
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirRecebimento">
                                        <i class="bi bi-box-arrow-in-right fs-4 mb-1"></i> Recebimento
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-secondary w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirEstoque">
                                        <i class="bi bi-box fs-4 mb-1"></i> Estoque
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-info w-100 py-3 d-flex flex-column align-items-center" @onclick="AbrirExpedicao">
                                        <i class="bi bi-truck fs-4 mb-1"></i> Expedição
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _carregando = true;
    private bool _isAdmin;

    // Abrir abas via acesso rápido
    private void AbrirArmazens() => TabService.OpenTab("Armazéns", "bi-building-add", typeof(Armazens));
    private void AbrirDepositantes() => TabService.OpenTab("Depositantes", "bi-building", typeof(Depositantes));
    private void AbrirUsuarios() => TabService.OpenTab("Usuários", "bi-people-fill", typeof(Usuarios));
    private void AbrirRecebimento() => TabService.OpenTab("Recebimento", "bi-box-arrow-in-right", typeof(Recebimento));
    private void AbrirEstoque() => TabService.OpenTab("Estoque", "bi-box", typeof(Estoque));
    private void AbrirExpedicao() => TabService.OpenTab("Expedição", "bi-truck", typeof(Expedicao));
    private string? _userId;
    private string _nomeUsuario = "";
    private string _meuPapel = "-";

    private int _totalArmazens;
    private int _totalDepositantes;
    private int _totalUsuarios;
    private int _depositantesInativos;

    private List<Armazem> _armazens = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        _isAdmin = user.IsInRole("Admin");
        _nomeUsuario = user.Identity?.Name ?? "Usuário";

        await using var db = await DbFactory.CreateDbContextAsync();

        // Buscar nome real do usuário
        if (_userId is not null)
        {
            var appUser = await db.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Id == _userId);
            if (appUser is not null)
            {
                _nomeUsuario = appUser.Nome;
            }
        }

        if (_isAdmin)
        {
            _totalArmazens = await db.Armazens.AsNoTracking().CountAsync(a => a.Ativo);
            _totalDepositantes = await db.Depositantes.AsNoTracking().CountAsync(d => d.Ativo);
            _depositantesInativos = await db.Depositantes.AsNoTracking().CountAsync(d => !d.Ativo);
            _totalUsuarios = await db.Users.AsNoTracking().CountAsync();
            _armazens = await db.Armazens.AsNoTracking()
                .OrderByDescending(a => a.DataCriacao)
                .Take(5)
                .ToListAsync();
        }
        else
        {
            var meusArmazemIds = await db.UsuarioArmazens.AsNoTracking()
                .Where(ua => ua.UsuarioId == _userId)
                .Select(ua => ua.ArmazemId)
                .ToListAsync();

            _totalArmazens = meusArmazemIds.Count;
            _totalDepositantes = await db.Depositantes.AsNoTracking()
                .CountAsync(d => d.Ativo && meusArmazemIds.Contains(d.ArmazemId));

            _armazens = await db.Armazens.AsNoTracking()
                .Where(a => meusArmazemIds.Contains(a.Id))
                .OrderBy(a => a.Nome)
                .ToListAsync();

            // Buscar papel do usuário (pegar o mais relevante)
            var papeis = await db.UsuarioArmazens.AsNoTracking()
                .Where(ua => ua.UsuarioId == _userId)
                .Select(ua => ua.Role)
                .Distinct()
                .ToListAsync();
            _meuPapel = papeis.Count switch
            {
                0 => "Sem acesso",
                1 => papeis[0],
                _ => string.Join(" / ", papeis)
            };
        }

        _carregando = false;
    }
}
