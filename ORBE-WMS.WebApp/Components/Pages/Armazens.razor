@* Componente renderizado dentro do sistema de abas *@
@implements IDisposable

@using ORBE_WMS.Application.DTOs
@using ORBE_WMS.Application.Services
@using ORBE_WMS.WebApp.Services

@inject ArmazemAppService ArmazemService
@inject TabService TabService
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Armazéns - ORBE WMS</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Armazéns</h4>
    <button class="btn btn-primary" @onclick="CriarArmazem">
        <i class="bi bi-plus-lg me-1"></i> Novo Armazém
    </button>
</div>

@if (_carregando)
{
    <div class="progress" style="height: 3px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated w-100" role="progressbar"></div>
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex align-items-center">
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar armazém..." @bind="_searchString" @bind:event="oninput" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>CNPJ</th>
                        <th>Endereço</th>
                        <th>Status</th>
                        <th>Criado em</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ArmazensFiltrados.Any())
                    {
                        @foreach (var context in ArmazensFiltrados)
                        {
                            <tr>
                                <td>@context.Nome</td>
                                <td>@context.CNPJ</td>
                                <td>@context.Endereco</td>
                                <td>
                                    @if (context.Ativo)
                                    {
                                        <span class="badge bg-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inativo</span>
                                    }
                                </td>
                                <td>@context.DataCriacao.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" title="Editar" @onclick="() => EditarArmazem(context)">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="btn btn-sm @(context.Ativo ? "btn-outline-danger" : "btn-outline-success") me-1" 
                                            title="@(context.Ativo ? "Desativar" : "Ativar")"
                                            @onclick="() => ToggleAtivo(context)">
                                        <i class="bi @(context.Ativo ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" title="Excluir" @onclick="() => Excluir(context)">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Nenhum armazém encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<ArmazemDto> _armazens = [];
    private bool _carregando = true;
    private string _searchString = "";
    private bool _wasActive = true;

    private IEnumerable<ArmazemDto> ArmazensFiltrados => _armazens.Where(x =>
        string.IsNullOrWhiteSpace(_searchString) ||
        x.Nome.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        (x.CNPJ != null && x.CNPJ.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
        (x.Endereco != null && x.Endereco.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
    );

    protected override async Task OnInitializedAsync()
    {
        TabService.OnTabsChanged += HandleTabFocus;
        await CarregarDados();
    }

    private async void HandleTabFocus()
    {
        var isActive = TabService.ActiveTab?.ComponentType == typeof(Armazens);
        if (isActive && !_wasActive)
        {
            await InvokeAsync(async () =>
            {
                await CarregarDados();
                StateHasChanged();
            });
        }
        _wasActive = isActive;
    }

    public void Dispose()
    {
        TabService.OnTabsChanged -= HandleTabFocus;
    }

    private async Task CarregarDados()
    {
        _carregando = true;
        _armazens = await ArmazemService.ObterTodosAsync();
        _carregando = false;
    }

    private void CriarArmazem()
    {
        TabService.OpenFormTab("✚ Novo Armazém", "bi-plus-circle", typeof(FormArmazem), new Dictionary<string, object>
        {
            ["ArmazemId"] = 0
        });
    }

    private void EditarArmazem(ArmazemDto armazem)
    {
        TabService.OpenFormTab($"✏ Editar: {armazem.Nome}", "bi-pencil-square", typeof(FormArmazem), new Dictionary<string, object>
        {
            ["ArmazemId"] = armazem.Id
        });
    }

    private async Task ToggleAtivo(ArmazemDto armazem)
    {
        try
        {
            var novoStatus = await ArmazemService.ToggleAtivoAsync(armazem.Id);
            var status = novoStatus ? "ativado" : "desativado";
            ToastService.Success($"Armazém \"{armazem.Nome}\" {status} com sucesso!");
            await CarregarDados();
        }
        catch (Exception ex)
        {
            ToastService.Error($"Erro ao alterar status: {ex.Message}");
        }
    }

    private async Task Excluir(ArmazemDto armazem)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Deseja realmente excluir o armazém \"{armazem.Nome}\"? Depositantes e vínculos de usuários serão removidos.");
        if (!confirmado) return;

        try
        {
            await ArmazemService.RemoverAsync(armazem.Id);
            ToastService.Success($"Armazém \"{armazem.Nome}\" excluído com sucesso!");
            await CarregarDados();
        }
        catch (Exception ex)
        {
            ToastService.Error($"Erro ao excluir armazém: {ex.Message}");
        }
    }
}
