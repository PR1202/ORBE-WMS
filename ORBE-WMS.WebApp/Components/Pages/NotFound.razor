@page "/not-found"
@layout MainLayout

<PageTitle>Página não encontrada - ORBE WMS</PageTitle>

<div class="d-flex flex-column align-items-center justify-content-center py-5">
    <div class="text-center">
        <div class="mb-4" style="font-size: 4rem; color: #adb5bd;">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h1 class="display-5 fw-bold text-dark mb-2">404</h1>
        <h4 class="text-muted mb-3">Página não encontrada</h4>
        <p class="text-muted mb-4" style="max-width: 400px; margin: 0 auto;">
            A página que você está procurando não existe ou foi movida.
        </p>
        <a href="/" class="btn btn-primary px-4 py-2">
            <i class="bi bi-house-door me-2"></i>Voltar ao Dashboard
        </a>
    </div>
</div>