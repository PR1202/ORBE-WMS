@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using ORBE_WMS.WebApp.Data

@inject UserManager<ApplicationUser> UserManager

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
            @(UsuarioId is not null ? "Editar Usuário" : "Novo Usuário")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (!string.IsNullOrEmpty(_erro))
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_erro</MudAlert>
        }

        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudTextField @bind-Value="_model.Nome"
                          Label="Nome Completo"
                          Required="true"
                          RequiredError="Nome é obrigatório"
                          MaxLength="200"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_model.Email"
                          Label="Email"
                          Required="true"
                          RequiredError="Email é obrigatório"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Disabled="@(_editando)"
                          Class="mb-3" />

            @if (!_editando)
            {
                <MudTextField @bind-Value="_model.Senha"
                              Label="Senha"
                              Required="true"
                              RequiredError="Senha é obrigatória"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.ConfirmarSenha"
                              Label="Confirmar Senha"
                              Required="true"
                              RequiredError="Confirmação é obrigatória"
                              InputType="InputType.Password"
                              Variant="Variant.Outlined"
                              Validation="@(new Func<string, string?>(ValidarConfirmacao))"
                              Class="mb-3" />
            }
            else
            {
                <MudSwitch @bind-Value="_model.Ativo" Label="Usuário Ativo"
                           Color="Color.Success" Class="mb-3" />
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!_formValido || _salvando)">
            @if (_salvando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Salvar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string? UsuarioId { get; set; }

    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;
    private bool _editando;
    private string? _erro;
    private UsuarioModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        if (UsuarioId is not null)
        {
            _editando = true;
            var user = await UserManager.FindByIdAsync(UsuarioId);
            if (user is not null)
            {
                _model = new UsuarioModel
                {
                    Nome = user.Nome,
                    Email = user.Email ?? string.Empty,
                    Ativo = user.Ativo
                };
            }
        }
    }

    private string? ValidarConfirmacao(string confirmacao)
    {
        if (confirmacao != _model.Senha)
            return "As senhas não coincidem";
        return null;
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;

        _salvando = true;
        _erro = null;

        try
        {
            if (_editando)
            {
                var user = await UserManager.FindByIdAsync(UsuarioId!);
                if (user is not null)
                {
                    user.Nome = _model.Nome;
                    user.Ativo = _model.Ativo;
                    var result = await UserManager.UpdateAsync(user);
                    if (!result.Succeeded)
                    {
                        _erro = string.Join(", ", result.Errors.Select(e => e.Description));
                        return;
                    }
                }
            }
            else
            {
                var user = new ApplicationUser
                {
                    UserName = _model.Email,
                    Email = _model.Email,
                    Nome = _model.Nome,
                    Ativo = true,
                    EmailConfirmed = true
                };

                var result = await UserManager.CreateAsync(user, _model.Senha);
                if (!result.Succeeded)
                {
                    _erro = string.Join(", ", result.Errors.Select(e => e.Description));
                    return;
                }
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _salvando = false;
        }
    }

    private void Cancelar() => MudDialog.Cancel();

    private class UsuarioModel
    {
        [Required(ErrorMessage = "Nome é obrigatório")]
        [MaxLength(200)]
        public string Nome { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email é obrigatório")]
        [EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = string.Empty;

        public string Senha { get; set; } = string.Empty;

        public string ConfirmarSenha { get; set; } = string.Empty;

        public bool Ativo { get; set; } = true;
    }
}
