@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using ORBE_WMS.WebApp.Data

@inject ApplicationDbContext Db

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
            @(DepositanteId.HasValue ? "Editar Depositante" : "Novo Depositante")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudSelect T="int" @bind-Value="_model.ArmazemId"
                       Label="Armazém" Required="true"
                       RequiredError="Armazém é obrigatório"
                       Variant="Variant.Outlined"
                       Class="mb-3">
                @foreach (var a in _armazens)
                {
                    <MudSelectItem T="int" Value="@a.Id">@a.Nome</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_model.Nome"
                          Label="Nome"
                          Required="true"
                          RequiredError="Nome é obrigatório"
                          MaxLength="200"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_model.CNPJ"
                          Label="CNPJ"
                          MaxLength="18"
                          Placeholder="00.000.000/0000-00"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_model.CodigoExterno"
                          Label="Código Externo"
                          MaxLength="100"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_model.Endereco"
                          Label="Endereço"
                          MaxLength="500"
                          Lines="2"
                          Variant="Variant.Outlined"
                          Class="mb-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!_formValido || _salvando)">
            @if (_salvando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Salvar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int? DepositanteId { get; set; }

    [Parameter]
    public int? ArmazemIdPadrao { get; set; }

    /// <summary>
    /// Lista de IDs de armazéns que o usuário tem permissão de acessar.
    /// Se null ou vazia, carrega todos os ativos (comportamento Admin).
    /// </summary>
    [Parameter]
    public List<int>? ArmazemIdsPermitidos { get; set; }

    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;
    private DepositanteModel _model = new();
    private List<Armazem> _armazens = [];

    protected override async Task OnInitializedAsync()
    {
        var query = Db.Armazens.AsNoTracking().Where(a => a.Ativo);
        if (ArmazemIdsPermitidos is { Count: > 0 })
        {
            query = query.Where(a => ArmazemIdsPermitidos.Contains(a.Id));
        }
        _armazens = await query.OrderBy(a => a.Nome).ToListAsync();

        if (DepositanteId.HasValue)
        {
            var depositante = await Db.Depositantes.AsNoTracking().FirstOrDefaultAsync(d => d.Id == DepositanteId.Value);
            if (depositante is not null)
            {
                _model = new DepositanteModel
                {
                    ArmazemId = depositante.ArmazemId,
                    Nome = depositante.Nome,
                    CNPJ = depositante.CNPJ,
                    CodigoExterno = depositante.CodigoExterno,
                    Endereco = depositante.Endereco
                };
            }
        }
        else if (ArmazemIdPadrao.HasValue)
        {
            _model.ArmazemId = ArmazemIdPadrao.Value;
        }
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;

        _salvando = true;
        try
        {
            if (DepositanteId.HasValue)
            {
                var depositante = await Db.Depositantes.FindAsync(DepositanteId.Value);
                if (depositante is not null)
                {
                    depositante.ArmazemId = _model.ArmazemId;
                    depositante.Nome = _model.Nome;
                    depositante.CNPJ = _model.CNPJ;
                    depositante.CodigoExterno = _model.CodigoExterno;
                    depositante.Endereco = _model.Endereco;
                    await Db.SaveChangesAsync();
                    Db.ChangeTracker.Clear();
                }
            }
            else
            {
                var depositante = new Depositante
                {
                    ArmazemId = _model.ArmazemId,
                    Nome = _model.Nome,
                    CNPJ = _model.CNPJ,
                    CodigoExterno = _model.CodigoExterno,
                    Endereco = _model.Endereco
                };
                Db.Depositantes.Add(depositante);
                await Db.SaveChangesAsync();
                Db.ChangeTracker.Clear();
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _salvando = false;
        }
    }

    private void Cancelar() => MudDialog.Cancel();

    private class DepositanteModel
    {
        [Required(ErrorMessage = "Armazém é obrigatório")]
        [Range(1, int.MaxValue, ErrorMessage = "Selecione um armazém")]
        public int ArmazemId { get; set; }

        [Required(ErrorMessage = "Nome é obrigatório")]
        [MaxLength(200)]
        public string Nome { get; set; } = string.Empty;

        [MaxLength(18)]
        public string? CNPJ { get; set; }

        [MaxLength(100)]
        public string? CodigoExterno { get; set; }

        [MaxLength(500)]
        public string? Endereco { get; set; }
    }
}
